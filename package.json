{
  "name": "rtr-mrp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && npx prisma db push --skip-generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:add-demo": "tsx scripts/add-demo-user.ts",
    "load:smoke": "k6 run load-testing/k6/main.js --env SCENARIO=smoke",
    "load:test": "k6 run load-testing/k6/main.js",
    "load:stress": "k6 run load-testing/k6/main.js --env SCENARIO=stress",
    "load:api": "k6 run load-testing/k6/api-tests.js",
    "clean": "rm -rf .next public/sw.js public/workbox-*.js public/fallback-*.js",
    "artillery:smoke": "artillery run load-testing/artillery/smoke.yml",
    "artillery:main": "artillery run load-testing/artillery/main.yml",
    "artillery:stress": "artillery run load-testing/artillery/stress.yml"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.962.0",
