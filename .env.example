# ═══════════════════════════════════════════════════════════════════════════════
#                         RTR MRP SYSTEM
#                    Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
#
# ═══════════════════════════════════════════════════════════════════════════════

# ==================== Database ====================
# For Docker deployment:
DATABASE_URL="postgresql://rtr:your-secure-password@db:5432/rtr_mrp?schema=public"

# For local development:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rtr_mrp?schema=public"

# Docker-specific database config
POSTGRES_USER=rtr
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=rtr_mrp

# ==================== Redis Cache ====================
# For Docker deployment:
REDIS_URL=redis://redis:6379

# For local development:
# REDIS_URL=redis://localhost:6379

# ==================== Authentication ====================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
# Generate with: openssl rand -base64 32

# ==================== Application ====================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV=production
APP_PORT=3000
SERVICE_NAME=rtr-mrp

# ==================== Monitoring ====================
# Sentry error tracking (optional)
SENTRY_DSN=

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# ==================== Backup ====================
BACKUP_RETENTION_DAYS=30

# ==================== Optional: AWS S3 Backup ====================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# ==================== Optional: Slack Notifications ====================
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx

# ==================== Optional: AI Features ====================
# OPENAI_API_KEY=sk-xxx

# ==================== ML Service ====================
ML_SERVICE_URL=http://ml-service:8000

# ==================== Docker Compose Ports ====================
DB_PORT=5432
REDIS_PORT=6379
ML_SERVICE_PORT=8000
