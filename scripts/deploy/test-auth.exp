#!/usr/bin/expect -f
set timeout 60
spawn ssh lam@171.244.40.23
expect "password:" { send "Tranthiquynh1987@\r" }
expect "\\$"

send "cat > /tmp/test-auth.sh << 'SCRIPT'\r"
expect ">"
send "TOKEN=$(curl -s -X POST https://auth.rtrobotics.com/api/auth/login -H 'Content-Type: application/json' -d '{\"email\":\"lam.nguyen@rtrobotics.me\",\"password\":\"Tranthiquynh1987@\"}' -D /tmp/auth-headers.txt -o /tmp/auth-body.txt)\r"
expect ">"
send "echo '=== Login response ==='\r"
expect ">"
send "cat /tmp/auth-body.txt\r"
expect ">"
send "echo ''\r"
expect ">"
send "echo '=== Cookies ==='\r"
expect ">"
send "grep -i set-cookie /tmp/auth-headers.txt\r"
expect ">"
send "TOKEN=$(grep rtr_access_token /tmp/auth-headers.txt | sed 's/.*rtr_access_token=//;s/;.*//')\r"
expect ">"
send "echo \"Token length: ${#TOKEN}\"\r"
expect ">"
send "echo '=== Test /api/v2/auth/me with token ==='\r"
expect ">"
send "curl -s https://mrp.rtrobotics.com/api/v2/auth/me -b \"rtr_access_token=$TOKEN\"\r"
expect ">"
send "echo ''\r"
expect ">"
send "echo '=== Test /home with token ==='\r"
expect ">"
send "curl -sI https://mrp.rtrobotics.com/home -b \"rtr_access_token=$TOKEN\" | head -5\r"
expect ">"
send "echo '=== Test /home without token ==='\r"
expect ">"
send "curl -sI https://mrp.rtrobotics.com/home | head -5\r"
expect ">"
send "echo '=== DONE ==='\r"
expect ">"
send "SCRIPT\r"
expect "\\$"

send "bash /tmp/test-auth.sh; echo XDONE\r"
expect "XDONE"
expect "\\$"

send "exit\r"
expect eof
