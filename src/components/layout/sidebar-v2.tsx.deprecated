    bgColor: 'bg-emerald-50 dark:bg-emerald-900/30',
  },
  {
    id: 'sales',
    label: 'Sales',
    labelVi: 'Bán hàng',
    icon: <ShoppingCart className="w-5 h-5" />,
    href: '/v2/sales',
    color: 'text-violet-600 dark:text-violet-400',
    bgColor: 'bg-violet-50 dark:bg-violet-900/30',
    badge: 5,
    badgeColor: 'bg-violet-500',
  },
  {
    id: 'mrp',
    label: 'MRP Planning',
