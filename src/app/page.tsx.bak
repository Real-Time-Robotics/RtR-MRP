    nav_docs: 'Tài liệu',
    nav_api: 'API',
    nav_dashboard: 'Mở Dashboard',

    // Hero
    hero_badge: 'Hệ thống MRP Doanh nghiệp',
    hero_title: 'Hoạch định Tài nguyên Sản xuất',
    hero_subtitle: 'Giải pháp toàn diện cho quản lý tồn kho, sản xuất và chất lượng. Được xây dựng cho sản xuất drone hiện đại.',
    hero_cta: 'Truy cập Dashboard',
