// =============================================================================
// MAIN COMPONENT
// =============================================================================

export default function LandingPage() {
  const [lang, setLang] = useState<Language>('en');
  const [theme, setTheme] = useState<Theme>('dark');
  const [mounted, setMounted] = useState(false);
  const [scrolled, setScrolled] = useState(false);

  const t = translations[lang];
  const isDark = theme === 'dark';

  useEffect(() => {
    setMounted(true);
    if (window.matchMedia('(prefers-color-scheme: light)').matches) {
      setTheme('light');
    }
    const handleScroll = () => setScrolled(window.scrollY > 20);
    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  if (!mounted) {
    return (
      <div className="min-h-screen bg-[#09090b]" />
    );
  }

  return (
    <div className={`min-h-screen font-[system-ui] antialiased ${isDark ? 'bg-[#09090b] text-zinc-50' : 'bg-white text-zinc-900'}`}>

      {/* ================================================================== */}
      {/* NAVIGATION */}
      {/* ================================================================== */}

      <nav className={`fixed top-0 left-0 right-0 z-50 transition-all duration-500 ${
        scrolled
          ? isDark
            ? 'bg-[#09090b]/80 backdrop-blur-2xl border-b border-zinc-800/50'
            : 'bg-white/80 backdrop-blur-2xl border-b border-zinc-200/50'
          : 'bg-transparent'
      }`}>
        <div className="max-w-6xl mx-auto px-6">
          <div className="flex items-center justify-between h-16">
            {/* Logo */}
            <div className="flex items-center gap-2.5">
              <div className={`w-7 h-7 rounded-md flex items-center justify-center ${isDark ? 'bg-white' : 'bg-zinc-900'}`}>
                <span className={`text-xs font-bold ${isDark ? 'text-zinc-900' : 'text-white'}`}>R</span>
              </div>
              <span className="text-sm font-semibold tracking-tight">RTR MRP</span>
            </div>

            {/* Center Nav */}
            <div className="hidden md:flex items-center gap-1">
              {[
                { href: '#features', label: t.nav_features },
                { href: '#docs', label: t.nav_docs },
                { href: '#api', label: t.nav_api },
              ].map((item) => (
                <a
                  key={item.href}
                  href={item.href}
                  className={`px-4 py-2 text-[13px] font-medium rounded-lg transition-colors ${
                    isDark ? 'text-zinc-400 hover:text-white hover:bg-white/5' : 'text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100'
                  }`}
                >
                  {item.label}
                </a>
              ))}
            </div>

            {/* Right Actions */}
            <div className="flex items-center gap-2">
              <button
                onClick={() => setLang(lang === 'en' ? 'vi' : 'en')}
                className={`h-8 px-3 text-[11px] font-semibold tracking-wide rounded-md transition-all ${
                  isDark ? 'bg-zinc-800 text-zinc-300 hover:bg-zinc-700' : 'bg-zinc-100 text-zinc-600 hover:bg-zinc-200'
                }`}
              >
                {lang === 'en' ? 'VI' : 'EN'}
              </button>

              <button
                onClick={() => setTheme(isDark ? 'light' : 'dark')}
                className={`w-8 h-8 flex items-center justify-center rounded-md transition-all ${
                  isDark ? 'bg-zinc-800 text-zinc-300 hover:bg-zinc-700' : 'bg-zinc-100 text-zinc-600 hover:bg-zinc-200'
                }`}
              >
                {isDark ? <Sun className="w-3.5 h-3.5" /> : <Moon className="w-3.5 h-3.5" />}
              </button>

              <Link
                href="/v2/dashboard"
                className={`hidden sm:flex items-center gap-1.5 h-8 px-4 text-[13px] font-medium rounded-md transition-all ${
                  isDark ? 'bg-white text-zinc-900 hover:bg-zinc-100' : 'bg-zinc-900 text-white hover:bg-zinc-800'
                }`}
              >
                {t.nav_dashboard}
                <ArrowRight className="w-3.5 h-3.5" />
              </Link>
            </div>
          </div>
        </div>
      </nav>

      {/* ================================================================== */}
      {/* HERO */}
      {/* ================================================================== */}

      <section className="relative pt-32 pb-20 overflow-hidden">
        {/* Subtle gradient */}
        <div className="absolute inset-0 overflow-hidden pointer-events-none">
          <div className={`absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full blur-[150px] ${
            isDark ? 'bg-blue-500/5' : 'bg-blue-500/10'
          }`} />
        </div>

        <div className="relative max-w-6xl mx-auto px-6">
          <div className="max-w-3xl">
            {/* Badge */}
            <div className={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-[11px] font-medium tracking-wide uppercase mb-8 ${
              isDark ? 'bg-zinc-800/80 text-zinc-400 border border-zinc-700/50' : 'bg-zinc-100 text-zinc-600 border border-zinc-200'
            }`}>
              <span className="w-1.5 h-1.5 rounded-full bg-emerald-500" />
              {t.hero_badge}
            </div>

            {/* Title */}
            <h1 className={`text-4xl sm:text-5xl lg:text-6xl font-bold tracking-[-0.02em] leading-[1.1] mb-6 ${
              isDark ? 'gradient-text' : 'gradient-text-light'
            }`}>
              {t.hero_title}
            </h1>

            {/* Subtitle */}
            <p className={`text-lg lg:text-xl leading-relaxed mb-10 max-w-2xl ${
              isDark ? 'text-zinc-400' : 'text-zinc-600'
            }`}>
              {t.hero_subtitle}
            </p>

            {/* CTAs */}
            <div className="flex flex-wrap gap-3">
              <Link
                href="/v2/dashboard"
                className={`inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-lg transition-all hover:scale-[1.02] active:scale-[0.98] ${
                  isDark ? 'bg-white text-zinc-900 hover:bg-zinc-100' : 'bg-zinc-900 text-white hover:bg-zinc-800'
                }`}
              >
                {t.hero_cta}
                <ArrowRight className="w-4 h-4" />
              </Link>
              <a
                href="#docs"
                className={`inline-flex items-center gap-2 px-6 py-3 text-sm font-medium rounded-lg transition-all ${
                  isDark ? 'bg-zinc-800 text-zinc-200 hover:bg-zinc-700' : 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200'
                }`}
              >
                <BookOpen className="w-4 h-4" />
                {t.hero_docs}
              </a>
            </div>
          </div>

          {/* Stats */}
          <div className={`mt-20 grid grid-cols-2 lg:grid-cols-4 gap-px rounded-xl overflow-hidden ${
            isDark ? 'bg-zinc-800/50' : 'bg-zinc-200'
          }`}>
            {[
              { value: '1,250+', label: t.stats_parts },
              { value: '10K+', label: t.stats_orders },
              { value: '99.9%', label: t.stats_uptime },
              { value: '24', label: t.stats_api },
            ].map((stat, i) => (
              <div key={i} className={`px-6 py-8 text-center ${isDark ? 'bg-[#09090b]' : 'bg-white'}`}>
                <div className="text-2xl lg:text-3xl font-bold tracking-tight">{stat.value}</div>
                <div className={`text-xs mt-1 ${isDark ? 'text-zinc-500' : 'text-zinc-500'}`}>{stat.label}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ================================================================== */}
      {/* FEATURES */}
      {/* ================================================================== */}

      <section id="features" className="py-24">
        <div className="max-w-6xl mx-auto px-6">
          <div className="max-w-xl mb-16">
            <h2 className="text-2xl lg:text-3xl font-bold tracking-tight mb-3">
              {t.features_title}
            </h2>
            <p className={`text-base ${isDark ? 'text-zinc-400' : 'text-zinc-600'}`}>
              {t.features_subtitle}
            </p>
          </div>

          <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
            {[
              { icon: Package, title: t.feat_inventory, desc: t.feat_inventory_desc },
              { icon: Factory, title: t.feat_production, desc: t.feat_production_desc },
              { icon: Shield, title: t.feat_quality, desc: t.feat_quality_desc },
              { icon: BarChart3, title: t.feat_analytics, desc: t.feat_analytics_desc },
              { icon: Lock, title: t.feat_security, desc: t.feat_security_desc },
              { icon: Code, title: t.feat_api, desc: t.feat_api_desc },
            ].map((feat, i) => (
              <div
                key={i}
                className={`group p-6 rounded-xl transition-all ${
                  isDark
                    ? 'bg-zinc-900/50 border border-zinc-800 hover:border-zinc-700 hover:bg-zinc-900'
                    : 'bg-zinc-50 border border-zinc-200 hover:border-zinc-300 hover:bg-white'
                }`}
              >
                <div className={`w-10 h-10 rounded-lg flex items-center justify-center mb-4 ${
                  isDark ? 'bg-zinc-800' : 'bg-white border border-zinc-200'
                }`}>
                  <feat.icon className={`w-5 h-5 ${isDark ? 'text-zinc-300' : 'text-zinc-700'}`} />
                </div>
                <h3 className="text-sm font-semibold mb-2">{feat.title}</h3>
                <p className={`text-sm leading-relaxed ${isDark ? 'text-zinc-500' : 'text-zinc-600'}`}>
                  {feat.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ================================================================== */}
      {/* TECH STACK */}
      {/* ================================================================== */}

      <section className={`py-24 ${isDark ? 'bg-zinc-900/30' : 'bg-zinc-50'}`}>
        <div className="max-w-6xl mx-auto px-6">
          <div className="text-center max-w-xl mx-auto mb-12">
            <h2 className="text-2xl lg:text-3xl font-bold tracking-tight mb-3">
              {t.tech_title}
            </h2>
            <p className={`text-base ${isDark ? 'text-zinc-400' : 'text-zinc-600'}`}>
              {t.tech_subtitle}
            </p>
          </div>

          <div className="flex flex-wrap justify-center gap-3">
            {[
              { name: 'Next.js 14', icon: '⚡' },
              { name: 'TypeScript', icon: '📘' },
              { name: 'Tailwind CSS', icon: '🎨' },
              { name: 'PostgreSQL', icon: '🐘' },
              { name: 'Prisma', icon: '◮' },
              { name: 'Vitest', icon: '🧪' },
            ].map((tech, i) => (
              <div
                key={i}
                className={`inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm ${
                  isDark ? 'bg-zinc-800/80 border border-zinc-700/50' : 'bg-white border border-zinc-200'
                }`}
              >
                <span>{tech.icon}</span>
                <span className={`font-medium ${isDark ? 'text-zinc-300' : 'text-zinc-700'}`}>{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* ================================================================== */}
      {/* DOCUMENTATION */}
      {/* ================================================================== */}

      <section id="docs" className="py-24">
        <div className="max-w-6xl mx-auto px-6">
          <div className="max-w-xl mb-16">
            <h2 className="text-2xl lg:text-3xl font-bold tracking-tight mb-3">
              {t.docs_title}
            </h2>
            <p className={`text-base ${isDark ? 'text-zinc-400' : 'text-zinc-600'}`}>
              {t.docs_subtitle}
            </p>
          </div>

          <div className="grid md:grid-cols-2 gap-4">
            {[
              { icon: Terminal, title: t.doc_setup, desc: t.doc_setup_desc, href: '/docs/SETUP.md' },
              { icon: Code, title: t.doc_api, desc: t.doc_api_desc, href: '/docs/API.md' },
              { icon: Layers, title: t.doc_arch, desc: t.doc_arch_desc, href: '/docs/ARCHITECTURE.md' },
              { icon: Database, title: t.doc_components, desc: t.doc_components_desc, href: '/docs/COMPONENTS.md' },
            ].map((doc, i) => (
              <Link
                key={i}
                href={doc.href}
                className={`group flex items-start gap-4 p-5 rounded-xl transition-all ${
                  isDark
                    ? 'bg-zinc-900/50 border border-zinc-800 hover:border-zinc-700'
                    : 'bg-zinc-50 border border-zinc-200 hover:border-zinc-300'
                }`}
              >
                <div className={`w-10 h-10 rounded-lg flex items-center justify-center shrink-0 ${
                  isDark ? 'bg-zinc-800' : 'bg-white border border-zinc-200'
                }`}>
                  <doc.icon className={`w-5 h-5 ${isDark ? 'text-zinc-400' : 'text-zinc-600'}`} />
                </div>
                <div className="flex-1 min-w-0">
                  <div className="flex items-center gap-2">
                    <span className="text-sm font-semibold">{doc.title}</span>
                    <ArrowUpRight className={`w-3.5 h-3.5 opacity-0 transition-all group-hover:opacity-100 ${
                      isDark ? 'text-zinc-500' : 'text-zinc-400'
                    }`} />
                  </div>
                  <p className={`text-sm mt-1 ${isDark ? 'text-zinc-500' : 'text-zinc-600'}`}>
                    {doc.desc}
                  </p>
                </div>
              </Link>
            ))}
          </div>
        </div>
      </section>

      {/* ================================================================== */}
      {/* API SECTION */}
      {/* ================================================================== */}

      <section id="api" className={`py-24 ${isDark ? 'bg-zinc-900/30' : 'bg-zinc-50'}`}>
        <div className="max-w-6xl mx-auto px-6">
          <div className="grid lg:grid-cols-2 gap-12 items-center">
            <div>
              <h2 className="text-2xl lg:text-3xl font-bold tracking-tight mb-4">
                REST API
              </h2>
              <p className={`text-base mb-8 ${isDark ? 'text-zinc-400' : 'text-zinc-600'}`}>
                {lang === 'en'
                  ? '24 endpoints with webhooks and comprehensive documentation'
                  : '24 endpoints với webhooks và tài liệu toàn diện'}
              </p>

              <div className="space-y-2">
                {[
                  { method: 'GET', path: '/api/v2/dashboard' },
                  { method: 'GET', path: '/api/v2/parts' },
                  { method: 'POST', path: '/api/v2/sales' },
                  { method: 'GET', path: '/api/v2/analytics' },
                ].map((endpoint, i) => (
                  <div
                    key={i}
                    className={`flex items-center gap-3 px-4 py-2.5 rounded-lg font-mono text-sm ${
                      isDark ? 'bg-zinc-800/50' : 'bg-white border border-zinc-200'
                    }`}
                  >
                    <span className={`text-xs font-bold ${
                      endpoint.method === 'GET' ? 'text-emerald-500' : 'text-blue-500'
                    }`}>
                      {endpoint.method}
                    </span>
                    <span className={isDark ? 'text-zinc-300' : 'text-zinc-700'}>{endpoint.path}</span>
                  </div>
                ))}
              </div>
            </div>

            <div className={`rounded-xl overflow-hidden ${isDark ? 'bg-[#0c0c0c] border border-zinc-800' : 'bg-zinc-900'}`}>
              <div className="flex items-center gap-1.5 px-4 py-3 border-b border-zinc-800">
                <div className="w-2.5 h-2.5 rounded-full bg-red-500/80" />
                <div className="w-2.5 h-2.5 rounded-full bg-yellow-500/80" />
                <div className="w-2.5 h-2.5 rounded-full bg-green-500/80" />
                <span className="ml-3 text-[11px] text-zinc-500 font-mono">response.json</span>
              </div>
              <pre className="p-5 text-[13px] text-zinc-300 font-mono overflow-x-auto leading-relaxed">
{`{
  "success": true,
  "data": {
    "kpis": {
      "inventory": {
        "totalParts": 1250,
        "lowStockParts": 23
      },
      "sales": {
        "totalOrders": 156,
        "monthlyRevenue": 450000
      }
    }
  }
}`}
              </pre>
            </div>
          </div>
        </div>
      </section>

      {/* ================================================================== */}
      {/* CTA */}
      {/* ================================================================== */}

      <section className="py-24">
        <div className="max-w-6xl mx-auto px-6">
          <div className={`rounded-2xl p-12 lg:p-16 text-center ${isDark ? 'bg-white' : 'bg-zinc-900'}`}>
            <h2 className={`text-2xl lg:text-3xl font-bold tracking-tight mb-4 ${isDark ? 'text-zinc-900' : 'text-white'}`}>
              {t.cta_title}
            </h2>
            <p className={`text-base mb-8 max-w-lg mx-auto ${isDark ? 'text-zinc-600' : 'text-zinc-400'}`}>
              {t.cta_subtitle}
            </p>
            <Link
              href="/v2/dashboard"
              className={`inline-flex items-center gap-2 px-8 py-4 text-sm font-medium rounded-lg transition-all hover:scale-[1.02] ${
                isDark ? 'bg-zinc-900 text-white hover:bg-zinc-800' : 'bg-white text-zinc-900 hover:bg-zinc-100'
              }`}
            >
              {t.cta_button}
              <ArrowRight className="w-4 h-4" />
            </Link>
          </div>
        </div>
      </section>

      {/* ================================================================== */}
      {/* FOOTER */}
      {/* ================================================================== */}

      <footer className={`border-t ${isDark ? 'border-zinc-800' : 'border-zinc-200'}`}>
        <div className="max-w-6xl mx-auto px-6 py-12">
          <div className="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
            <div>
              <h4 className="text-xs font-semibold uppercase tracking-wider mb-4 text-zinc-500">{t.footer_product}</h4>
              <div className="space-y-3">
                {['Features', 'Dashboard', 'API'].map((item) => (
                  <a key={item} href="#" className={`block text-sm transition-colors ${isDark ? 'text-zinc-400 hover:text-white' : 'text-zinc-600 hover:text-zinc-900'}`}>{item}</a>
                ))}
              </div>
            </div>
            <div>
              <h4 className="text-xs font-semibold uppercase tracking-wider mb-4 text-zinc-500">{t.footer_resources}</h4>
              <div className="space-y-3">
                {['Documentation', 'Setup Guide', 'API Reference'].map((item) => (
                  <a key={item} href="#" className={`block text-sm transition-colors ${isDark ? 'text-zinc-400 hover:text-white' : 'text-zinc-600 hover:text-zinc-900'}`}>{item}</a>
                ))}
              </div>
            </div>
            <div>
              <h4 className="text-xs font-semibold uppercase tracking-wider mb-4 text-zinc-500">{t.footer_company}</h4>
              <div className="space-y-3">
                {['About', 'Contact', 'Careers'].map((item) => (
                  <a key={item} href="#" className={`block text-sm transition-colors ${isDark ? 'text-zinc-400 hover:text-white' : 'text-zinc-600 hover:text-zinc-900'}`}>{item}</a>
                ))}
              </div>
            </div>
            <div>
              <h4 className="text-xs font-semibold uppercase tracking-wider mb-4 text-zinc-500">{t.footer_legal}</h4>
              <div className="space-y-3">
                {['Privacy', 'Terms', 'Security'].map((item) => (
                  <a key={item} href="#" className={`block text-sm transition-colors ${isDark ? 'text-zinc-400 hover:text-white' : 'text-zinc-600 hover:text-zinc-900'}`}>{item}</a>
                ))}
              </div>
            </div>
          </div>

          <div className={`flex flex-col md:flex-row items-center justify-between pt-8 border-t ${isDark ? 'border-zinc-800' : 'border-zinc-200'}`}>
            <div className="flex items-center gap-2.5 mb-4 md:mb-0">
              <div className={`w-6 h-6 rounded flex items-center justify-center ${isDark ? 'bg-white' : 'bg-zinc-900'}`}>
                <span className={`text-[10px] font-bold ${isDark ? 'text-zinc-900' : 'text-white'}`}>R</span>
              </div>
              <span className={`text-xs ${isDark ? 'text-zinc-500' : 'text-zinc-600'}`}>{t.footer_copyright}</span>
            </div>
            <div className="flex items-center gap-2">
              <a href="#" className={`w-8 h-8 flex items-center justify-center rounded-md transition-colors ${isDark ? 'hover:bg-zinc-800 text-zinc-500' : 'hover:bg-zinc-100 text-zinc-500'}`}>
                <Github className="w-4 h-4" />
              </a>
              <a href="#" className={`w-8 h-8 flex items-center justify-center rounded-md transition-colors ${isDark ? 'hover:bg-zinc-800 text-zinc-500' : 'hover:bg-zinc-100 text-zinc-500'}`}>
                <Mail className="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </footer>
    </div>
  );
}
