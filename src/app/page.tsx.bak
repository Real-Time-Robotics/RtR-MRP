'use client';

import React, { useState, useEffect } from 'react';
import Link from 'next/link';
import {
  ArrowRight,
  ArrowUpRight,
  Moon,
  Sun,
  Package,
  Factory,
  BarChart3,
  Shield,
  Code,
  BookOpen,
  Terminal,
  Layers,
  Database,
  Lock,
  Github,
  Mail,
} from 'lucide-react';

// =============================================================================
